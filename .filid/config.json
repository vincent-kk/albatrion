{
  "version": "1.0",
  "language": "ko",
  "rules": {
    "naming-convention": {
      "enabled": true,
      "severity": "warning"
    },
    "organ-no-intentmd": {
      "enabled": true,
      "severity": "error"
    },
    "index-barrel-pattern": {
      "enabled": true,
      "severity": "warning"
    },
    "module-entry-point": {
      "enabled": true,
      "severity": "warning",
      "allowed-no-entry": ["packages/slats/claude-assets-sync"]
    },
    "max-depth": {
      "enabled": true,
      "severity": "error"
    },
    "circular-dependency": {
      "enabled": true,
      "severity": "error"
    },
    "pure-function-isolation": {
      "enabled": true,
      "severity": "error"
    },
    "zero-peer-file": {
      "enabled": true,
      "severity": "warning",
      "additional-allowed": [
        "packages/slats/claude-assets-sync/src/prompts/*.ts",
        "type.ts",
        "CLAUDE.md",
        "LICENSE",
        "README.md",
        "README-ko_kr.md",
        "eslint.config.js",
        "package.json",
        "rollup.config.mjs",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.declarations.json"
      ]
    }
  }
}
