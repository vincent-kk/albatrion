{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "stripInternal": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "removeComments": false,
    "declarationDir": "dist",
    "declarationMap": false,
    "composite": false,
    "noEmit": false,
    "paths": {
      "@/schema-form": ["./src"],
      "@/schema-form/*": ["./src/*"],
      "@aileron/*": ["../../aileron/common/*", "./dist/@aileron/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "**/__tests__/**",
    "**/coverage/**",
    "**/stories/**",
    "**/*.test.tsx?",
    "**/*.spec.tsx?",
    "**/*.story.tsx?",
    "**/*.stories.tsx?"
  ]
}
