{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "outDir": "./dist",
    "paths": {
      "@/schema-form": ["./canard/schema-form/src"],
      "@/schema-form/*": ["./canard/schema-form/src/*"],
      "@aileron/*": ["./aileron/common/*"]
    }
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.tsx",
    "stories/**/*.ts",
    "stories/**/*.tsx",
    "bench/**/*.ts",
    "vitest.bench.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
