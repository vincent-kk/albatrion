{
  "name": "@aileron/benchmark-form",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "node --expose-gc --import tsx src/index.ts",
    "bench:all": "node --expose-gc --import tsx src/index.ts --all-versions",
    "bench:repeat": "node --expose-gc --import tsx src/index.ts --all-versions --repeat=5",
    "bench:scale": "node --expose-gc --import tsx src/index.ts --scale --no-core",
    "bench:scale:repeat": "node --expose-gc --import tsx src/index.ts --scale --no-core --repeat=3",
    "bench:array-stress": "node --expose-gc --import tsx src/index.ts --array-stress --no-core",
    "bench:full": "node --expose-gc --import tsx src/index.ts --scale --array-stress",
    "bench:full:repeat": "node --expose-gc --import tsx src/index.ts --scale --array-stress --repeat=3",
    "regression-check": "node --import tsx src/utils/regression-check.ts",
    "stat-regression": "node --import tsx src/utils/stat-regression.ts",
    "heap-snapshot": "node --expose-gc --import tsx src/utils/heap-snapshot.tsx",
    "heap-parse": "node --import tsx src/utils/parse-heapsnapshot.ts",
    "summary": "node --import tsx src/utils/summary.ts",
    "bench:compare": "node --expose-gc --import tsx src/utils/compare-frameworks.tsx",
    "render-trace": "node --expose-gc --import tsx src/utils/render-trace.tsx",
    "guard:baseline": "node --expose-gc --import tsx src/index.ts --scale --array-stress --repeat=5 --min-samples=8 --max-time=2 --exclude=array-500,array-1000 --out=results/baseline.json",
    "guard:check": "node --expose-gc --import tsx src/index.ts --scale --array-stress --repeat=5 --min-samples=8 --max-time=2 --exclude=array-500,array-1000 --out=results/current.json && node --import tsx src/utils/stat-regression.ts --baseline results/baseline.json --current results/current.json --fail"
  },
  "dependencies": {
    "@canard/schema-form": "workspace:^",
    "@canard/schema-form_0.10.0": "npm:@canard/schema-form@0.10.0",
    "@canard/schema-form_0.11.0": "npm:@canard/schema-form@0.11.0",
    "@canard/schema-form_0.12.0": "npm:@canard/schema-form@0.12.0",
    "@canard/schema-form_0.12.5": "npm:@canard/schema-form@0.12.5",
    "@canard/schema-form_0.9.0": "npm:@canard/schema-form@0.9.0",
    "@rjsf/core": "^6.6.1",
    "@rjsf/utils": "^6.6.1",
    "@rjsf/validator-ajv8": "^6.6.1",
    "@tanstack/react-form": "^1.33.0",
    "benchmark": "^2.1.4",
    "formik": "^2.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.1",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.1.0"
  }
}
