{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "outDir": "./dist",
    "paths": {
      "@/promise-modal": ["./lerx/promise-modal/src"],
      "@/promise-modal/*": ["./lerx/promise-modal/src/*"],
      "@aileron/*": ["./aileron/common/*"]
    }
  },
  "include": [
    "src",
    "src/**/*.tsx?",
    "coverage/**/*.tsx?",
    "stories/**/*.ts",
    "stories/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
