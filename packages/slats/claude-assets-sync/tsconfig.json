{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@/claude-assets-sync": ["./src"],
      "@/claude-assets-sync/*": ["./src/*"],
      "@aileron/*": ["../../aileron/common/*"]
    }
  },
  "include": ["src", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
