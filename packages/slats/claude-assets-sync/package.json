{
  "name": "@slats/claude-assets-sync",
  "version": "0.2.0",
  "description": "Shared CLI engine that lets consumer packages inject their Claude docs (skills, rules, commands) into a user's .claude directory via a thin bin/inject-docs wrapper.",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "inject",
    "docs",
    "skills",
    "assets"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/albatrion.git",
    "directory": "packages/slats/claude-assets-sync"
  },
  "license": "MIT",
  "author": {
    "name": "Vincent K. Kelvin",
    "email": "lunox273@gmail.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/program.d.ts",
      "source": "./src/program.ts",
      "import": "./dist/program.mjs",
      "require": "./dist/program.cjs"
    },
    "./buildHashes": {
      "import": "./scripts/buildHashes.mjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-assets-sync": "./dist/cli.mjs",
    "claude-build-hashes": "./scripts/buildHashes.mjs"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/inject-version.js && rollup -c && yarn build:types",
    "build:publish:npm": "yarn build && yarn publish:npm",
    "build:types": "node ../../aileron/script/build/buildTypes.mjs",
    "dev": "node scripts/inject-version.js && tsx src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "publish:npm": "yarn npm publish --access public",
    "test": "vitest",
    "version:major": "yarn version major",
    "version:minor": "yarn version minor",
    "version:patch": "yarn version patch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^6.6.0",
    "ink-select-input": "^6.2.0",
    "picocolors": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0"
  }
}
