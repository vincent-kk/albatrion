{
  "name": "albatrion",
  "version": "0.0.0",
  "description": "none",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/albatrion.git",
    "owner": "vincent-kk"
  },
  "license": "MIT",
  "workspaces": [
    "documents",
    "packages/**/*"
  ],
  "scripts": {
    "benchmark": "yarn workspace @aileron/benchmark",
    "benchmark:form": "yarn workspace @aileron/benchmark-form",
    "build:all": "yarn run:all build",
    "changeset": "changeset",
    "changeset:publish": "yarn run:all && changeset publish",
    "changeset:version": "changeset version",
    "claudeAssetsSync": "yarn workspace @slats/claude-assets-sync",
    "commonUtils": "yarn workspace @winglet/common-utils",
    "dataLoader": "yarn workspace @winglet/data-loader",
    "deploy:docs": "yarn workspace @albatrion/documents deploy:gh-pages",
    "developmentHelper": "yarn workspace @aileron/development-helper",
    "documents": "yarn workspace @albatrion/documents",
    "import-test": "./scripts/test-package-import.sh",
    "import-test:winglet": "./scripts/test-winglet-import.sh",
    "json": "yarn workspace @winglet/json",
    "jsonSchema": "yarn workspace @winglet/json-schema",
    "major:all": "yarn workspaces foreach --all --topological-dev --no-private run version:major",
    "minor:all": "yarn workspaces foreach --all --topological-dev --no-private run version:minor",
    "npm:setup-token": "./scripts/setup-npm-token.sh",
    "npm:whoami": "yarn npm whoami",
    "patch:all": "yarn workspaces foreach --all --topological-dev --no-private run version:patch",
    "promiseModal": "yarn workspace @lerx/promise-modal",
    "publish:all": "yarn workspaces foreach --all --topological-dev --no-private run publish:npm",
    "reactUtils": "yarn workspace @winglet/react-utils",
    "run:all": "yarn workspaces foreach --all --topological-dev run",
    "schemaForm": "yarn workspace @canard/schema-form",
    "schemaForm:ajv6": "yarn workspace @canard/schema-form-ajv6-plugin",
    "schemaForm:ajv7": "yarn workspace @canard/schema-form-ajv7-plugin",
    "schemaForm:ajv8": "yarn workspace @canard/schema-form-ajv8-plugin",
    "schemaForm:antd5": "yarn workspace @canard/schema-form-antd5-plugin",
    "schemaForm:antd6": "yarn workspace @canard/schema-form-antd6-plugin",
    "schemaForm:antdMobile": "yarn workspace @canard/schema-form-antd-mobile-plugin",
    "schemaForm:mui": "yarn workspace @canard/schema-form-mui-plugin",
    "sort:packages": "npx sort-package-json '**/package.json'",
    "storybook:upgrade": "npx storybook@latest upgrade --yes",
    "styleUtils": "yarn workspace @winglet/style-utils",
    "sync:docs": "yarn workspace @albatrion/documents sync-api-docs",
    "tag:packages": "./scripts/tag-packages.sh",
    "testbed:production": "yarn workspace @aileron/production-testbed"
  },
  "resolutions": {
    "@eslint/config-array/minimatch": "^3.1.3",
    "@eslint/eslintrc/minimatch": "^3.1.3",
    "@humanwhocodes/config-array/minimatch": "^3.1.3",
    "anymatch/picomatch": "^2.3.2",
    "axios": "^1.15.0",
    "basic-ftp": "^5.2.2",
    "cosmiconfig/yaml": "^1.10.3",
    "express/path-to-regexp": "0.1.13",
    "flatted": "^3.4.2",
    "follow-redirects": "^1.16.0",
    "glob": "^10.5.0",
    "gray-matter/js-yaml": "^3.14.1",
    "jest-util/picomatch": "^2.3.2",
    "lodash": "^4.18.0",
    "mdast-util-to-hast": "^13.2.1",
    "micromatch/picomatch": "^2.3.2",
    "minimatch": "^9.0.7",
    "node-forge": "^1.4.0",
    "picomatch": "^4.0.4",
    "qs": "^6.14.2",
    "rimraf": "^5.0.10",
    "rollup": "^4.59.0",
    "serialize-javascript": "^7.0.5",
    "svgo": "^3.3.3",
    "tar": "^7.5.11",
    "undici": "^7.24.0",
    "uuid": "^14.0.0",
    "vite": "^7.3.2",
    "webpack": "^5.105.1",
    "webpack-dev-server": "^5.2.2",
    "ws": "^8.18.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@chromatic-com/storybook": "^5.0.1",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@size-limit/preset-app": "^11.1.6",
    "@size-limit/preset-big-lib": "^11.1.6",
